+
+SOFT_SKILL_RULES: tuple[tuple[str, tuple[str, ...]], ...] = (
+    ("Communication", (r"\bcommunication\s+skills?\b", r"\bcommunicat(?:e|ion)\b")),
+    ("Collaboration", (r"\bcollaborat(?:e|ion|ive)\b", r"\bteamwork\b")),
+    ("Problem Solving", (r"\bproblem[- ]solving\b", r"\bsolve\s+complex\s+problems?\b")),
+    ("Analytical Thinking", (r"\banalytical\s+(?:skills?|thinking)\b",)),
+    ("Attention to Detail", (r"\battention\s+to\s+detail\b",)),
+    ("Adaptability", (r"\badaptab(?:le|ility)\b", r"\bfast[- ]paced\b")),
+    ("Leadership", (r"\bleadership\s+skills?\b",)),
+    ("Stakeholder Management", (r"\bstakeholder\s+management\b",)),
+    ("Time Management", (r"\btime\s+management\b",)),
+    ("Curiosity", (r"\bcurios(?:ity|ious)\b",)),
+)
+
+DEGREE_FIELD_RULES: tuple[tuple[str, tuple[str, ...]], ...] = (
+    ("Computer Science", (r"\bcomputer\s+science\b",)),
+    ("Information Technology", (r"\binformation\s+technology\b", r"\bit\s+degree\b")),
+    ("Software Engineering", (r"\bsoftware\s+engineering\b",)),
+    ("Information Systems", (r"\binformation\s+systems?\b",)),
+    ("Data Science", (r"\bdata\s+science\b",)),
+    ("Statistics", (r"\bstatistics?\b", r"\bstatistical\s+science\b")),
+    ("Mathematics", (r"\bmathematics?\b", r"\bmathematical\s+science\b")),
+    ("Engineering", (r"\bengineering\s+degree\b", r"\bdegree\s+in\s+engineering\b")),
+    ("Business", (r"\bbusiness\s+(?:degree|discipline|field)\b",)),
+    ("Finance", (r"\bfinance\s+(?:degree|discipline|field)\b",)),
+)
+
+DEGREE_REQUIRED_PATTERNS: tuple[str, ...] = (
+    r"\b(?:bachelor'?s?|bsc|b\.sc\.?|btech|b\.tech\.?|undergraduate)\s+(?:degree|qualification)\b",
+    r"\bdegree\s+(?:in|required|essential)\b",
+    r"\brelevant\s+(?:tertiary\s+)?qualification\b",
+    r"\bcomputer\s+science\s+degree\b",
+)
+
+DEGREE_OPTIONAL_PATTERNS: tuple[str, ...] = (
+    r"\bdegree\s+(?:is\s+)?(?:preferred|advantageous|a\s+plus)\b",
