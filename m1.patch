+        source=source,
+        client=StubClient(),
+        store=RawSnapshotStore(tmp_path),
+        collected_at=datetime(2026, 7, 22, tzinfo=timezone.utc),
+    )
+
+    assert result.status == "written"
+    assert result.source_token == "example"
+    assert result.job_count == 0
+    assert result.error is None
