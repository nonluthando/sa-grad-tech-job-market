+    config_path.write_text(
+        json.dumps(
+            {
+                "sources": [
+                    {
+                        "name": "Example",
+                        "provider": "greenhouse",
+                        "token": "example",
+                        "enabled": True,
+                    },
+                    {
+                        "name": "Other",
+                        "provider": "lever",
+                        "token": "other",
+                        "enabled": True,
+                    },
+                ]
+            }
+        ),
